{
  "name": "vrcpb-spike-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "M1 spike PoC: Next.js 15 App Router + Cloudflare Pages + Cookie/Session verification. Not for production use.",
  "scripts": {
