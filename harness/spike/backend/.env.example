# M1 spike backend PoC: 環境変数サンプル
# 実値はコミットしない。このファイルは「キー名と形式」を示すだけのサンプル。

# === アプリケーション ===
APP_ENV=local
PORT=8080

# === CORS / Origin チェック ===
# Frontend(OpenNext preview) / 検証ホストをカンマ区切りで列挙。
# 本実装では本番ドメインだけに絞る。
# 例: ALLOWED_ORIGINS=http://localhost:8787,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:8787,http://localhost:3000

# === PostgreSQL（ローカル docker-compose 起動時のサンプル値） ===
# 本番値は Secret Manager 経由で注入する想定
DATABASE_URL=postgres://vrcpb_spike:spike_local_password@localhost:5432/vrcpb_spike?sslmode=disable

# docker-compose.yaml が読み取る環境変数
POSTGRES_USER=vrcpb_spike
POSTGRES_PASSWORD=spike_local_password
POSTGRES_DB=vrcpb_spike
POSTGRES_PORT=5432

# === Cloudflare R2（M1 priority 4 R2 接続 PoC で使用） ===
# 実値は .env.local（git ignore 対象）で管理。本ファイルにはサンプルキー名のみ。
# 最小権限のテストトークン（M1 専用）を発行して使うこと。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vrcpb-spike
# R2 エンドポイント（{R2_ACCOUNT_ID} は実値を埋める）
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# === IP ハッシュソルト（v4 §3.7、本実装で必要） ===
# IP_HASH_SALT_V1=
# IP_HASH_SALT_CURRENT_VERSION=1
