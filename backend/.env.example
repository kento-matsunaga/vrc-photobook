# Backend 本実装：環境変数サンプル
# 実値はコミットしない。本ファイルは「キー名と形式」を示すサンプル。

# === アプリケーション ===
APP_ENV=local
PORT=8080

# === DB（PR3） ===
# ローカル開発用 DSN の例。実値は .env.local（git ignore 対象）または Secret Manager で管理。
# DATABASE_URL=postgres://vrcpb:vrcpb_local@localhost:5432/vrcpb?sslmode=disable

# docker-compose.yaml が読み取る変数（任意）
# POSTGRES_PASSWORD=vrcpb_local

# === 以下は PR7 以降で順次有効化 ===
# ALLOWED_ORIGINS=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=
# TURNSTILE_SECRET_KEY=
# SENDGRID_API_KEY=
