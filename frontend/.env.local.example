# Frontend ローカル開発用 環境変数サンプル
# 実値は .env.local（git ignore 対象）に書く。本ファイルにはキー名のみ。
#
# NEXT_PUBLIC_* は Next.js のビルド時に bundle に inline される「公開値」。
# Secret 値は決して NEXT_PUBLIC_ プレフィックスで渡さないこと。

# Frontend 自身の base URL（OGP / 内部リンク解決に使用、PR5 で metadataBase 設定時から有効）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Backend API base URL（PR5 以降で API 呼び出し開始時に使用）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
