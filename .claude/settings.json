{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/track-edit.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 scripts/hooks/quality-check/track-quality-edits.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/capture-test-result.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 scripts/hooks/quality-check/track-quality-execution.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check-untested.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 scripts/hooks/quality-check/stop-quality-check.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
