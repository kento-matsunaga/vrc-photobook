# ローカル専用ファイル
/tmp/
*.plan.md
PLAN.md
TASKS.md

# ハーネスの記録は git で共有する。
# - failure-log: feedback-loop.md の運用に従い、失敗→ルール化のために残す
# - work-logs: reconcile-scripts.md §6 の監査ログ運用に従い、実行記録を残す
# 個人情報・Secret を含む可能性のある記録は、別途下書き拡張子で除外する。
harness/failure-log/*.draft.md
harness/work-logs/*.draft.md

# フック追跡用一時ファイル
/tmp/ai-driven-edited-files.txt
/tmp/ai-driven-quality-state/

# OS
.DS_Store
Thumbs.db
# WSL: Windows から持ち込まれたファイルに付く NTFS 代替データストリーム
*:Zone.Identifier

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code ローカル設定（settings.local.json はローカル固有）
.claude/settings.local.json

# wrangler のローカル auth キャッシュ（OAuth refresh token などが含まれるため絶対にコミットしない）
.wrangler/

# failure-to-rule.sh で生成されるローカルルール（レビュー前）
# ※ レビュー後にgit addする運用
__pycache__/
*.pyc

# 検証用一時 cmd（公開 photobook を UseCase 経由で作る等）。commit せずローカル使用、
# 検証後削除する想定の場所。`backend/internal/photobook/wireup.CreateAndPublishForCLI`
# を呼び出す temp main を置くときに使う。
/backend/cmd/_test-publish-public/

# m2-design-refresh: design/usephot/ は user 個人撮影の VRChat 実写 PNG（合計約 78 MB、
# 9〜14 MB / 枚）。git 管理せず、後続 STOP で frontend/scripts/build-landing-images.sh
# 経由で WebP/JPEG variant に圧縮 → frontend/public/img/landing/ のみ git 管理する方針
# （docs/plan/m2-design-refresh-plan.md §3.4 / §9.3 / §3.5）。raw 個人写真を repo に
# 入れない（branch / merge での扱い・bundle size・写真権利の観点）。
design/usephot/
